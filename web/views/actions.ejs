<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Action Centre' }) %>
<body class="app-page">
  <div class="app-layout">
    <%- include('partials/sidebar', { page: 'actions' }) %>

    <main class="main-content">
      <div class="page-inner">

        <div class="page-header">
          <div class="page-header-text">
            <h1 class="page-title">Action Centre</h1>
            <p class="page-subtitle">Emails, dispute letters, and call scripts drafted for you</p>
          </div>
        </div>

        <div class="tab-bar">
          <a href="/actions" class="tab <%= activeStatus === 'all' ? 'active' : '' %>">All</a>
          <a href="/actions?status=draft" class="tab <%= activeStatus === 'draft' ? 'active' : '' %>">Draft</a>
          <a href="/actions?status=sent" class="tab <%= activeStatus === 'sent' ? 'active' : '' %>">Sent</a>
          <a href="/actions?status=resolved" class="tab <%= activeStatus === 'resolved' ? 'active' : '' %>">Resolved</a>
        </div>

        <% if (actions.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="empty-title">No action drafts yet</h3>
            <p class="empty-desc">Use the MCP tools to draft negotiation emails, dispute letters, or phone scripts.</p>
          </div>
        <% } else { %>
          <div class="actions-list">
            <% actions.forEach(function(a) { %>
              <%
                var typeBadge = 'badge-other';
                if (a.type === 'email') typeBadge = 'badge-email';
                else if (a.type === 'dispute_letter') typeBadge = 'badge-dispute';
                else if (a.type === 'phone_script') typeBadge = 'badge-script';
              %>
              <div class="action-card" data-action-id="<%= a.id %>">
                <div class="action-header" onclick="toggleAction(this)">
                  <div class="action-header-left">
                    <span class="badge <%= typeBadge %>"><%= a.type.replace(/_/g, ' ') %></span>
                    <span class="action-merchant"><%= a.merchant %></span>
                  </div>
                  <div class="action-header-right">
                    <span class="badge badge-status-<%= a.status %>"><%= a.status %></span>
                    <span class="action-date"><%= new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    <span class="action-chevron">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </span>
                  </div>
                </div>
                <div class="action-body" style="display:none;">
                  <pre class="action-content"><%= a.content %></pre>
                  <div class="action-controls">
                    <% if (a.status === 'draft') { %>
                      <button class="btn btn-primary btn-sm" onclick="updateStatus(<%= a.id %>, 'sent', this)">Mark as Sent</button>
                      <button class="btn btn-secondary btn-sm" onclick="openResolveModal(<%= a.id %>, '<%= a.merchant.replace(/'/g, "\\'") %>')">Mark as Resolved</button>
                    <% } else if (a.status === 'sent') { %>
                      <button class="btn btn-primary btn-sm" onclick="openResolveModal(<%= a.id %>, '<%= a.merchant.replace(/'/g, "\\'") %>')">Mark as Resolved</button>
                    <% } else { %>
                      <span class="action-resolved-label">Resolved</span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>

      </div>
    </main>
  </div>

  <!-- Resolve modal -->
  <div id="resolveModal" class="modal-overlay" style="display:none;" onclick="closeResolveModal(event)">
    <div class="modal-card" onclick="event.stopPropagation()">
      <h3 class="modal-title">Record outcome</h3>
      <p class="modal-sub" id="resolveModalMerchant"></p>

      <label class="modal-label">Outcome type</label>
      <div class="modal-row">
        <label class="radio-pill"><input type="radio" name="savingsType" value="recurring_monthly" checked onchange="toggleSavingsFields()"> Rate reduced (monthly)</label>
        <label class="radio-pill"><input type="radio" name="savingsType" value="one_time" onchange="toggleSavingsFields()"> One-time refund</label>
      </div>

      <div id="recurringFields">
        <label class="modal-label">Previous monthly charge</label>
        <input type="number" step="0.01" id="fromAmount" class="modal-input" placeholder="119">
        <label class="modal-label">New monthly charge</label>
        <input type="number" step="0.01" id="toAmount" class="modal-input" placeholder="76">
      </div>

      <div id="oneTimeFields" style="display:none;">
        <label class="modal-label">Refund amount</label>
        <input type="number" step="0.01" id="refundAmount" class="modal-input" placeholder="50">
      </div>

      <label class="modal-label">Note (optional)</label>
      <input type="text" id="outcomeNote" class="modal-input" placeholder="e.g. Rate reduced from $119 to $76">

      <div class="modal-actions">
        <button class="btn btn-secondary btn-sm" onclick="closeResolveModal()">Cancel</button>
        <button class="btn btn-primary btn-sm" onclick="confirmResolve()">Confirm</button>
      </div>

      <div id="projectionCard" class="projection-card" style="display:none;"></div>
    </div>
  </div>

  <style>
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-card { background: var(--bg-card, #fff); border-radius: 12px; padding: 24px; max-width: 480px; width: 90%; max-height: 90vh; overflow-y: auto; }
    .modal-title { margin: 0 0 4px; font-size: 18px; font-weight: 600; }
    .modal-sub { margin: 0 0 16px; color: var(--text-muted, #667); font-size: 14px; }
    .modal-label { display: block; margin: 12px 0 6px; font-size: 13px; font-weight: 500; }
    .modal-input { width: 100%; padding: 8px 12px; border: 1px solid #d0d5dd; border-radius: 8px; font-size: 14px; box-sizing: border-box; }
    .modal-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .radio-pill { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid #d0d5dd; border-radius: 999px; font-size: 13px; cursor: pointer; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px; }
    .projection-card { margin-top: 20px; padding: 16px; background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-radius: 10px; }
    .projection-title { font-weight: 600; margin: 0 0 4px; font-size: 14px; color: #065f46; }
    .projection-sub { font-size: 12px; color: #047857; margin: 0 0 12px; }
    .projection-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .projection-bucket { background: rgba(255,255,255,0.7); padding: 10px; border-radius: 8px; text-align: center; }
    .projection-years { font-size: 11px; color: #065f46; font-weight: 500; }
    .projection-value { font-size: 16px; font-weight: 700; color: #064e3b; margin-top: 2px; }
  </style>

  <script>
    var resolveActionId = null;

    function openResolveModal(id, merchant) {
      resolveActionId = id;
      document.getElementById('resolveModalMerchant').textContent = merchant;
      document.getElementById('fromAmount').value = '';
      document.getElementById('toAmount').value = '';
      document.getElementById('refundAmount').value = '';
      document.getElementById('outcomeNote').value = '';
      document.getElementById('projectionCard').style.display = 'none';
      document.querySelector('input[name="savingsType"][value="recurring_monthly"]').checked = true;
      toggleSavingsFields();
      document.getElementById('resolveModal').style.display = 'flex';
    }

    function closeResolveModal(e) {
      if (e && e.target !== e.currentTarget) return;
      document.getElementById('resolveModal').style.display = 'none';
      if (document.getElementById('projectionCard').style.display === 'block') {
        window.location.reload();
      }
    }

    function toggleSavingsFields() {
      var type = document.querySelector('input[name="savingsType"]:checked').value;
      document.getElementById('recurringFields').style.display = type === 'recurring_monthly' ? 'block' : 'none';
      document.getElementById('oneTimeFields').style.display = type === 'one_time' ? 'block' : 'none';
    }

    function fmt(n) {
      return '$' + Math.round(n).toLocaleString();
    }

    async function confirmResolve() {
      var type = document.querySelector('input[name="savingsType"]:checked').value;
      var note = document.getElementById('outcomeNote').value;
      var body = { status: 'resolved', outcome: { savings_type: type, note: note } };

      if (type === 'recurring_monthly') {
        body.outcome.from_amount = parseFloat(document.getElementById('fromAmount').value);
        body.outcome.to_amount   = parseFloat(document.getElementById('toAmount').value);
      } else {
        body.outcome.amount = parseFloat(document.getElementById('refundAmount').value);
      }

      try {
        var res = await fetch('/actions/' + resolveActionId + '/status', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        var data = await res.json();
        if (!res.ok) { alert(data.error || 'Failed'); return; }

        if (data.projection && data.savings) {
          var s = data.savings;
          var unit = s.savings_type === 'recurring_monthly' ? '/mo' : ' refund';
          var html = '<div class="projection-title">✓ Saving recorded: ' + fmt(s.amount) + unit + '</div>' +
                     '<div class="projection-sub">If redirected to investments at 7% annual return:</div>' +
                     '<div class="projection-grid">';
          data.projection.forEach(function(p) {
            html += '<div class="projection-bucket"><div class="projection-years">' + p.years + ' years</div>' +
                    '<div class="projection-value">' + fmt(p.future_value) + '</div></div>';
          });
          html += '</div>';
          document.getElementById('projectionCard').innerHTML = html;
          document.getElementById('projectionCard').style.display = 'block';
        } else {
          window.location.reload();
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
  </script>

  <script>
    function toggleAction(header) {
      var body = header.nextElementSibling;
      var chevron = header.querySelector('.action-chevron');
      var isOpen = body.style.display !== 'none';
      body.style.display = isOpen ? 'none' : 'block';
      chevron.classList.toggle('open', !isOpen);
    }

    async function updateStatus(id, status, btn) {
      try {
        var res = await fetch('/actions/' + id + '/status', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: status })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to update status.');
        }
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
  </script>
</body>
</html>
